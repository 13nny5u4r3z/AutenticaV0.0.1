# ============================
# ENTORNO
# ============================
NODE_ENV=development
PORT=3000

# ============================
# BASE DE DATOS - MySQL
# ============================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=asesoria_imagen
DB_USER=root
DB_PASSWORD=

# Pool de conexiones
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# ============================
# JWT
# ============================
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=cambia_esto_por_otro_secreto_largo_y_aleatorio
JWT_REFRESH_EXPIRES_IN=7d

# ============================
# ENCRIPTACIÓN (Dirección/Teléfono en Envio)
# ============================
# Clave AES-256-GCM: exactamente 64 caracteres hexadecimales (32 bytes)
ENCRYPTION_KEY=cambia_esto_por_64_caracteres_hexadecimales_aleatorios_00000000000

# ============================
# CORS
# ============================
CORS_ORIGIN=http://localhost:5173

# ============================
# MERCADO PAGO
# ============================
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=

# ============================
# NODEMAILER (SMTP)
# ============================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Asesorías de Imagen <no-reply@asesoria.com>"

# ============================
# RATE LIMITING
# ============================
# Ventana en minutos y máximo de peticiones
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# ============================
# LOGS (winston)
# ============================
LOG_LEVEL=debug
